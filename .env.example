# Copy to .env — /new-agent generates MASTER_KEY for you; never invent one.
#
# ┌─ WHAT GOES IN .env ───────────────────────────────────────────────────────┐
# │  Operational vars: port, public URL, MASTER_KEY, Bedrock region/model,    │
# │  CORS origins, DEV_MODE.  That's it.                                      │
# │                                                                            │
# │  WHAT DOES NOT GO IN .env:                                                 │
# │  • LLM API keys — Bedrock authenticates via IAM role (no key needed).     │
# │    Azure/OpenAI: the SDK reads the SecretStr from env automatically via    │
# │    Pydantic-settings; you add the field to your Settings subclass.         │
# │  • Upstream/vendor API keys (e.g. financial data, CRM, graph APIs) —      │
# │    these live in the encrypted credential store (AES-256-GCM, keyed by    │
# │    MASTER_KEY). Configure them once via the admin console at /admin;       │
# │    access them in your adapter with self.credential("field_name").         │
# │    Writing a vendor key here is a SI-6 violation caught by /redteam.      │
# └───────────────────────────────────────────────────────────────────────────┘

AGENT_NAME={{AGENT_NAME}}
# Port this agent listens on locally. Set by /setup (scans 8000-8020 for a free
# port); change here if you need a different one. All skills read this value.
AGENT_PORT=

# REQUIRED outside DEV_MODE. Every advertised URL (agent card, OAuth
# metadata, AG-UI endpoint) derives from this. One origin per agent.
PUBLIC_URL=

# >=32 chars, generated. Encrypts the credential store (AES-256-GCM).
# This is NOT a service API key — it protects the local DB of upstream keys.
# Rotation: python -m agent_sdk rotate-master-key (offline only).
MASTER_KEY=

# Bedrock (v1 default model backend) — no API key; IAM role grants access.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ARN=

# DEV_MODE relaxes exactly: MASTER_KEY strength, PUBLIC_URL requirement,
# secure-transport checks on OAuth endpoints. Nothing else. A non-localhost
# PUBLIC_URL with DEV_MODE=true is a hard boot failure.
DEV_MODE=false

# Explicit list, never a wildcard.
CORS_ORIGINS=["https://claude.ai"]

# Where the encrypted credential DB lives (the Docker volume).
DATA_DIR=/data
