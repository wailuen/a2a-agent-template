# Copy to .env — /setup generates MASTER_KEY for you; never invent one.
#
# ┌─ WHAT GOES IN .env ────────────────────────────────────────────────────────┐
# │  Operational vars only: PORT, PUBLIC_URL, MASTER_KEY, DEV_MODE,           │
# │  CORS_ORIGINS, DATA_DIR, Bedrock region/model, OpenAI model name/         │
# │  Azure endpoint (non-secret). That's it.                                  │
# │                                                                            │
# │  WHAT DOES NOT GO IN .env (SI-6 violation — caught by /redteam):          │
# │  • LLM API keys (OpenAI, Azure, Anthropic, etc.) — seed once via the      │
# │    admin console at /admin → Model Backend; the SDK reads from the         │
# │    encrypted credential store at boot. Never in .env, ever.               │
# │  • Upstream/vendor API keys (financial data, CRM, Graph, etc.) —          │
# │    configure once via /admin → Credentials; access in your adapter with   │
# │    self.credential("field_name"). Never in .env.                           │
# └────────────────────────────────────────────────────────────────────────────┘

AGENT_NAME={{AGENT_NAME}}
# 1-2 sentence description used by A2A registries for agent discovery and task routing.
# Run /update-card-description to generate this from your current tools and skills.
AGENT_DESCRIPTION=
# Port this agent listens on locally. Set by /setup (scans 8000-8020 for a free
# port); change here if you need a different one. All skills read this value.
AGENT_PORT=

# REQUIRED outside DEV_MODE. Every advertised URL (agent card, OAuth
# metadata, AG-UI endpoint) derives from this. One origin per agent.
PUBLIC_URL=

# >=32 chars, generated. Encrypts the credential store (AES-256-GCM).
# This is NOT a service API key — it protects the local DB of upstream keys.
# Rotation: python -m agent_sdk rotate-master-key (offline only).
MASTER_KEY=

# ── Model backend (choose ONE; API key NEVER goes here) ─────────────────────
#
# Option A — Bedrock (default): IAM role grants access; no API key.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ARN=

# Option B — OpenAI: set OPENAI_MODEL here (non-secret); seed the API key
# once via /provision or /admin → Model Backend → openai_api_key.
# OPENAI_MODEL=
# OPENAI_BASE_URL=          # optional; leave blank for openai.com default

# Option C — Azure OpenAI: set endpoint + deployment here (non-secret);
# seed the API key once via /admin → Model Backend → azure_openai_api_key.
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_API_VERSION=2025-01-01-preview

# DEV_MODE relaxes exactly: MASTER_KEY strength, PUBLIC_URL requirement,
# secure-transport checks on OAuth endpoints. Nothing else. A non-localhost
# PUBLIC_URL with DEV_MODE=true is a hard boot failure.
DEV_MODE=false

# Explicit list, never a wildcard.
CORS_ORIGINS=["https://claude.ai"]

# Where the encrypted credential DB lives (the Docker volume).
DATA_DIR=/data

# ── Azure Storage (optional; enables multi-replica deployments) ──────────────
# Set ONE of the following — never both.
# When set, credentials, commitments, and subscription state are stored in
# Azure Table Storage instead of local SQLite files, enabling multi-replica
# Azure Container Apps deployments.
#
# LOCAL DEV — Azurite (Azure Storage emulator, no az login required):
#   Install: npm install -g azurite   or   brew install azurite
#   Start:   azurite --silent --location /tmp/azurite
# AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
#
# DEV/TEST against real Azure (treat as secret; do not commit):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
#
# Managed identity (production ACA — preferred; omit connection string):
# AZURE_STORAGE_ACCOUNT_NAME=mystorageaccount
#
# Table name prefix (optional; default shown):
# AZURE_STORAGE_TABLE_PREFIX=agent
