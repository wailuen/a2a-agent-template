{
  "permissions": {
    "allow": [
      "Agent(*)",
      "Read(**)",
      "Bash(find . *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(python3.12 *)",
      "Bash(.venv/bin/uvicorn *)",
      "Bash(.venv/bin/python *)",
      "Bash(uv *)",
      "Bash(VIRTUAL_ENV=* uv pip install *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(curl *)",
      "Bash(ssh *)",
      "Bash(lsof *)",
      "Bash(gh *)",
      "Bash(cat pyproject.toml)",
      "Bash(cat *requirements*.txt)"
    ],
    "deny": [
      "Read(*.db)",
      "Read(*.sqlite)",
      "Read(.data/*)",
      "Bash(cat .env)",
      "Bash(cat .env.local)",
      "Bash(cat */.env)",
      "Bash(cat */.env.local)",
      "Bash(*MASTER_KEY*)",
      "Bash(*master_key*)",
      "Bash(*SECRET=*)",
      "Bash(*PASSWORD=*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"\nimport sys, json\ntry:\n    raw = sys.stdin.read()\n    if '/admin/api/credentials' in raw and ('PUT' in raw or 'POST' in raw):\n        print('CREDENTIAL-HOOK: A credential was just written. Immediately update workspace/adr/ADR-001-<env>-credentials.md — record the namespace + field name that was seeded (never the value). If the file does not exist yet, create it from the template in /provision Phase 3b.')\nexcept:\n    pass\n\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
